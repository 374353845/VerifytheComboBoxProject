<?xml version="1.0" encoding="utf-8"?><!-- res/drawable/seekbar_progress.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 未滑过部分（背景） -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <!-- 正方形背景色 -->
            <solid android:color="#F7F9FA" />
            <!-- 正方形大小（宽高一致） -->
            <size
                android:width="50dp"
                android:height="50dp" />
            <!-- 可选：添加圆角（如需纯正方形可设为0） -->
            <corners android:radius="2dp" />
            <!-- 可选：添加边框 -->
            <stroke
                android:width="1dp"
                android:color="#E4E7EB" />
        </shape>
    </item>
    <!-- 已滑过部分（进度） -->
    <item android:id="@android:id/progress">
        <clip>
        <shape android:shape="rectangle">
            <!-- 正方形背景色 -->
            <solid android:color="#D1E9FE" />
            <!-- 正方形大小（宽高一致） -->
            <size
                android:width="50dp"
                android:height="50dp" />
            <!-- 可选：添加圆角（如需纯正方形可设为0） -->
            <corners android:radius="2dp" />
            <!-- 可选：添加边框 -->
            <stroke
                android:width="1dp"
                android:color="#1891FA" />
        </shape>
        </clip>

    </item>
</layer-list>